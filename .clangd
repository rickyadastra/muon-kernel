SemanticTokens:
  DisabledKinds: [Typedef, Type]
Diagnostics:
  Suppress: ["unsupported option '-mabi='", "microsoft-anon-tag"]

If:
  PathMatch: bootloader/boson/.*
CompileFlags:
  CompilationDatabase: build/boson
---
If:
  PathMatch: bootloader/kernel/.*
CompileFlags:
  CompilationDatabase: build/kernel
