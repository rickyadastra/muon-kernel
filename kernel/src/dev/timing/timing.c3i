module dev::timing;

faultdef WALLCLOCK_NOT_SET, TIMER_UNSUPPORTED;

alias TimerCallbackFn = fn void(TimerEvent*);
alias KernelTime = ulong;

interface Timer {
    fn void set(KernelTime time);
    fn void cancel();

    fn double get_frequency();
    fn KernelTime get_current();
}

struct TimerEvent {
    KernelTime timestamp;
    TimerCallbackFn callback;
    any context;
    bitstruct : char {
        bool isCancelled : 0;
    }
}
