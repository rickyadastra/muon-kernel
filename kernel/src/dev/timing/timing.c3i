module dev::timing;

faultdef WALLCLOCK_NOT_SET, TIMER_UNSUPPORTED;

alias TimerCallbackFn = fn void(Timer*);

interface Timer {
    fn void set(ulong time);
    fn void cancel();

    fn double get_frequency();
    fn ulong get_current();
}

struct TimerEvent {
    ulong timestamp;
    TimerCallbackFn callback;
}
