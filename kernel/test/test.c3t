module muon::test;

import process;
import muon;

macro prepare_scheduler() {
    process::spawn(&test::task_simple_counter)!!;
    process::spawn(&test::task_spawner)!!;
    process::spawn(&test::task_intensive_loop)!!;
    process::spawn(&test::task_quick_exit)!!;
    process::spawn(&test::task_conditional_logic)!!;
    process::spawn(&test::task_switch_logic)!!;
    process::spawn(&test::task_yield_stress)!!;
}

macro prepare_scheduler_fpu() {
    process::spawn(&test::task_fpu_basic_arithmetic)!!;
    process::spawn(&test::task_fpu_accumulator)!!;
    process::spawn(&test::task_fpu_interleaved)!!;
    process::spawn(&test::task_fpu_double_precision)!!;
    process::spawn(&test::task_fpu_register_persistence)!!;
    process::spawn(&test::task_fpu_advanced_math)!!;
    process::spawn(&test::task_fpu_stress)!!;
    process::spawn(&test::task_fpu_division_chain)!!;
    process::spawn(&test::task_fpu_interleave_test_a)!!;
    process::spawn(&test::task_fpu_interleave_test_b)!!;
    process::spawn(&test::task_fpu_intensive_loop_1)!!;
    process::spawn(&test::task_fpu_intensive_loop_2)!!;
}
